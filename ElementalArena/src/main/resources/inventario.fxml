<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import java.net.URL?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #2b2b2b; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg126161.controller.InventarioController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <Label text="≡ INVENTARIO DI GIOCO" style="-fx-text-fill: #ffd700; -fx-font-weight: bold; -fx-font-size: 24px;"/>

    <Label fx:id="lblFeedback" text="Clicca su Usa/Equipaggia sotto l'oggetto desiderato" style="-fx-text-fill: #aaaaaa;"/>

    <ScrollPane fitToWidth="true" prefHeight="300.0" maxWidth="500.0">
        <content>
            <FlowPane fx:id="grigliaOggetti" hgap="15.0" vgap="15.0" alignment="CENTER" style="-fx-padding: 10;"/>
        </content>
    </ScrollPane>

    <Button text="Indietro alla Home" onAction="#handleIndietro" style="-fx-cursor: hand; -fx-margin-top: 10; -fx-background-color: #555555; -fx-text-fill: white;"/>

</VBox>