<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import java.net.URL?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #2b2b2b; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg126161.controller.SalvataggiController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <Label text="≡ SELEZIONA PARTITA" style="-fx-text-fill: #ffd700; -fx-font-weight: bold; -fx-font-size: 22px;"/>

    <ScrollPane fitToWidth="true" prefHeight="220.0" maxWidth="550.0">
        <content>
            <FlowPane fx:id="grigliaPartite" hgap="15.0" vgap="15.0" alignment="CENTER" style="-fx-padding: 10;"/>
        </content>
    </ScrollPane>

    <Label text="---------------- OPPURE CREA NUOVO EROE ----------------" style="-fx-text-fill: #888888;"/>

    <HBox alignment="CENTER" spacing="10.0">
        <TextField fx:id="campoNomeNuovoEroe" promptText="Nome Nuovo Eroe" style="-fx-pref-width: 200px; -fx-font-size: 14px;"/>
        <Button text="🔥 Inizia Avventura" onAction="#handleNuovoEroe" style="-fx-cursor: hand; -fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
    </HBox>

    <Button text="Indietro al Menu" onAction="#handleIndietro" style="-fx-cursor: hand; -fx-margin-top: 15; -fx-background-color: #555555; -fx-text-fill: white;"/>

</VBox>