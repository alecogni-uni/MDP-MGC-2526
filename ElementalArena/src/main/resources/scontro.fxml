<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ComboBox?>
<?import java.net.URL?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="850.0" prefHeight="750.0" style="-fx-background-color: #1a1a1a; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg126161.controller.ScontroController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <Label text="≡ ARENA DI COMBATTIMENTO ≡" style="-fx-text-fill: #ff4d4d; -fx-font-weight: bold; -fx-font-size: 24px;"/>

    <TextArea fx:id="txtBattleLog" editable="false" wrapText="true" prefRowCount="5" style="-fx-control-inner-background: #000000; -fx-text-fill: #00ff00; -fx-font-family: 'Consolas'; -fx-font-size: 14px; -fx-border-color: #555; -fx-max-width: 650px;"/>

    <HBox alignment="CENTER" spacing="40.0" style="-fx-margin-top: 10px;">
        <VBox spacing="8.0" style="-fx-background-color: #2b2b2b; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #4CAF50; -fx-border-radius: 8; -fx-min-width: 250px;">
            <Label fx:id="lblNomeEroe" text="EROE" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;"/>
            <ProgressBar fx:id="barraHpEroe" prefWidth="220" progress="1.0" style="-fx-accent: #4CAF50;"/>
            <Label fx:id="lblHpEroe" text="HP: 100/100" style="-fx-text-fill: #4CAF50; -fx-font-weight: bold;"/>
            <VBox style="-fx-background-color: #333; -fx-padding: 5; -fx-background-radius: 5;">
                <Label fx:id="lblElementoEroe" text="Elemento: LUCE" style="-fx-text-fill: #ccc;"/>
                <Label fx:id="lblForzaEroe" text="Forza Base: 5" style="-fx-text-fill: #ccc;"/>
                <Label fx:id="lblArmaEroe" text="Arma: Nessuna" style="-fx-text-fill: #ffaa00;"/>
            </VBox>
        </VBox>

        <Label text="VS" style="-fx-text-fill: #ffeb3b; -fx-font-size: 28px; -fx-font-weight: bold; -fx-font-style: italic;"/>

        <VBox spacing="8.0" style="-fx-background-color: #2b2b2b; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #ff4d4d; -fx-border-radius: 8; -fx-min-width: 250px;">
            <Label fx:id="lblNomeMostro" text="MOSTRO" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;" wrapText="true"/>
            <ProgressBar fx:id="barraHpMostro" prefWidth="220" progress="1.0" style="-fx-accent: #ff4d4d;"/>
            <Label fx:id="lblHpMostro" text="HP: ?/?" style="-fx-text-fill: #ff4d4d; -fx-font-weight: bold;"/>
            <VBox style="-fx-background-color: #333; -fx-padding: 5; -fx-background-radius: 5;">
                <Label fx:id="lblElementoMostro" text="Elemento: OSCURITA" style="-fx-text-fill: #ccc;"/>
                <Label fx:id="lblForzaMostro" text="Attacco Base: 10" style="-fx-text-fill: #ccc;"/>
                <Label text="Ricompensa: XP e $$" style="-fx-text-fill: #ffaa00;"/>
            </VBox>
        </VBox>
    </HBox>

    <HBox alignment="CENTER" spacing="20.0" style="-fx-margin-top: 15px;">
        <Button fx:id="btnAttacca" text="Attacca" onAction="#handleAttacca" style="-fx-font-size: 16px; -fx-min-width: 150px; -fx-background-color: #d9534f; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button fx:id="btnPozione" text="Usa Pozione" onAction="#handlePozione" style="-fx-font-size: 16px; -fx-min-width: 150px; -fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>

        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Arma Veloce:" style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px;"/>
            <ComboBox fx:id="cmbArmi" onAction="#handleCambiaArma" prefWidth="220" style="-fx-cursor: hand;"/>
        </VBox>
    </HBox>

    <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #222222; -fx-padding: 15; -fx-border-color: #444444; -fx-border-width: 1 0 0 0; -fx-margin-top: 10;">
        <Label text="LEGENDA ELEMENTI" style="-fx-text-fill: #ffaa00; -fx-font-size: 13px; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
        <HBox alignment="CENTER" spacing="30.0">
            <VBox alignment="CENTER" spacing="8.0" style="-fx-background-color: #2d2d2d; -fx-padding: 10; -fx-background-radius: 8; -fx-border-color: #555; -fx-border-radius: 8;">
                <Label text="Triangolo Base (Danno x2)" style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px; -fx-font-style: italic;"/>
                <HBox alignment="CENTER" spacing="10.0">
                    <Label text="FUOCO" style="-fx-text-fill: #ff4d4d; -fx-font-weight: bold;"/>
                    <Label text="&gt;" style="-fx-text-fill: #777777; -fx-font-weight: bold;"/>
                    <Label text="TERRA" style="-fx-text-fill: #cd853f; -fx-font-weight: bold;"/>
                    <Label text="&gt;" style="-fx-text-fill: #777777; -fx-font-weight: bold;"/>
                    <Label text="ACQUA" style="-fx-text-fill: #3399ff; -fx-font-weight: bold;"/>
                    <Label text="&gt;" style="-fx-text-fill: #777777; -fx-font-weight: bold;"/>
                    <Label text="FUOCO" style="-fx-text-fill: #ff4d4d; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
            <VBox alignment="CENTER" spacing="8.0" style="-fx-background-color: #2d2d2d; -fx-padding: 10; -fx-background-radius: 8; -fx-border-color: #555; -fx-border-radius: 8;">
                <Label text="Scontro Letale (Danno x2 reciproco)" style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px; -fx-font-style: italic;"/>
                <HBox alignment="CENTER" spacing="15.0">
                    <Label text="LUCE" style="-fx-text-fill: #ffff99; -fx-font-weight: bold;"/>
                    <Label text="&lt;--&gt;" style="-fx-text-fill: #777777; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label text="OSCURITA'" style="-fx-text-fill: #9932cc; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </HBox>
    </VBox>

    <Button fx:id="btnIndietro" text="Torna alla Home" onAction="#handleIndietro" visible="false" managed="false" style="-fx-cursor: hand; -fx-background-color: #555; -fx-text-fill: white;"/>

</VBox>