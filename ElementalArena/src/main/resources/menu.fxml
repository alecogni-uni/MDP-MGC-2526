<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #2b2b2b;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg126161.controller.MenuController">

    <Label text="⚔️ELEMENTAL ARENA⚔️" style="-fx-text-fill: #ffd700; -fx-font-weight: bold; -fx-font-size: 28px;"/>

    <Button text="Nuova Partita" onAction="#handleNuovaPartita" style="-fx-font-size: 16px; -fx-min-width: 200px; -fx-cursor: hand;"/>
    <Button text="Carica Salvataggio" onAction="#handleCaricaPartita" style="-fx-font-size: 16px; -fx-min-width: 200px; -fx-cursor: hand;"/>
    <Button text="Esci dal Gioco" onAction="#handleEsci" style="-fx-font-size: 16px; -fx-min-width: 200px; -fx-cursor: hand;"/>

</VBox>